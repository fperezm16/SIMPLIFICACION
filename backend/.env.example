# Copia este archivo como backend/.env y reemplaza los valores.
# No subas backend/.env a Git.
DATABASE_URL=postgres://USUARIO:CLAVE@HOST:5432/BASE_DE_DATOS?sslmode=require
DB_SSL_NO_VERIFY=false
PORT=4000
JWT_SECRET=cambia_esta_clave_por_una_segura
BACKEND_BASE_URL=http://localhost:4000

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@midominio.com
SENDGRID_FROM_NAME=Formulario TG

