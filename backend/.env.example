# Copia este archivo como backend/.env y reemplaza los valores.
# No subas backend/.env a Git.
DATABASE_URL=postgres://postgres:TU_CLAVE@localhost:5432/formulario
PORT=4000
JWT_SECRET=cambia_esta_clave_por_una_segura
BACKEND_BASE_URL=http://localhost:4000
FRONTEND_BASE_URL=http://localhost:4200
CORS_ORIGIN=http://localhost:4200
NODE_ENV=development
ALLOW_DEV_AUTH_LINKS=false

# SMTP institucional
SMTP_HOST=mail.dgac.gob.gt
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sistema.pruebas@dgac.gob.gt
